  "query": "\n            SELECT asset,book_pda,seller,collection,price,status,metadata_url,\n                   metadata_hash,name,cover_url,author,series,category,condition,\n                   created_at,updated_at\n            FROM books\n            WHERE seller=$1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
