# 复制为 .env.local 并填写。修改 NEXT_PUBLIC_* 后需重启 next dev。
#
# API 基址必须与 book_server 一致：默认端口 3005，且路径含 /api。
# 切勿写成 http://IP/api（缺端口）——浏览器会走 80 端口 → ERR_CONNECTION_REFUSED。

# 仅在本机浏览器使用 http://localhost:3000 时：
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3005/api

# 手机或局域网访问 http://<电脑IP>:3000 时（把 IP 换成你的机器）：
# NEXT_PUBLIC_API_URL=http://10.141.210.224:3005/api

NEXT_PUBLIC_API_URL=http://127.0.0.1:3005/api
NEXT_PUBLIC_USE_MOCK_DATA=false
